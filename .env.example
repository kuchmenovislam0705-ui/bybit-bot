# Скопируй этот файл в .env и заполни своими ключами
# cp .env.example .env

BYBIT_API_KEY=вставь_сюда_api_key
BYBIT_API_SECRET=вставь_сюда_api_secret

# TESTNET=false  — реальная торговля (по умолчанию)
# TESTNET=true   — тестовая сеть Bybit
TESTNET=false

# PAPER_MODE=true  — симуляция сделок без реальных ордеров
PAPER_MODE=false
